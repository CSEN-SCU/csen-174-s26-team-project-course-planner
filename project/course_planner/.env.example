# After creating a key at https://aistudio.google.com/apikey, set one of:
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional: override the default model (default is gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# --- Google Sign-In (OAuth 2.0 web client) ---
# Create a Web application OAuth client: Google Cloud Console → APIs & Services → Credentials.
# The Authorized redirect URI registered in Google Console must match
# GOOGLE_OAUTH_REDIRECT_URI byte-for-byte, including the trailing slash.
# In production this MUST be an https:// URL — http is only acceptable for
# http://localhost during development.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501/
# Optional: restrict sign-in to a Google Workspace org. The check prefers
# the ID token's `hd` (hosted domain) claim and falls back to the email
# suffix for non-Workspace accounts. Explicit emails bypass the domain gate
# for approved test users.
# GOOGLE_OAUTH_ALLOWED_DOMAIN=scu.edu
# GOOGLE_OAUTH_ALLOWED_EMAILS=student@gmail.com,teammate@example.com
