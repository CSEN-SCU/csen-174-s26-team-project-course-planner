# API server env (FastAPI). The api also reads project/course_planner/.env
# first; values here override that.

# Optional: override the port main.py runs on (defaults to 8000 via uvicorn).
PORT=8000

# Used to sign OAuth state and the short-lived handoff token the API hands
# back to the SPA. MUST be set to a random 32-byte value in production —
# the dev default lets anyone forge a handoff token if they can reach the
# API.
SCU_PLANNER_COOKIE_KEY=dev-cookie-key-change-me

# Where to redirect the browser back to after Google sign-in. Default
# matches Vite's dev server.
FRONTEND_BASE_URL=http://localhost:5173

# --- Google Sign-In (OAuth 2.0 web client, FastAPI redirect) ---
# Create a Web application OAuth client at
# https://console.cloud.google.com/apis/credentials and register
#   http://localhost:8000/api/auth/google/callback
# as an Authorized redirect URI (byte-for-byte match, https in prod).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# GOOGLE_OAUTH_ALLOWED_DOMAIN=scu.edu
